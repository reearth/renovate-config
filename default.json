{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "minimumReleaseAge": "7 days",
  "extends": [
    "config:base",
    ":semanticCommits",
    ":semanticCommitScopeDisabled",
    ":maintainLockFilesWeekly",
    ":enableVulnerabilityAlertsWithLabel(security)",
    ":semanticCommitTypeAll(chore)"
  ],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": false
  },
  "separateMajorMinor": false,
  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths"
  ],
  "packageRules": [
    {
      "matchDepTypes": [
        "action"
      ],
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github action update or pin versions",
      "groupSlug": "pintagtodigest",
      "pinDigests": true,
      "matchUpdateTypes": [ "minor", "patch" ],
      "schedule": ["before 3:00 am on monday"],
      "semanticCommitType": "ci"
    },
    {
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["actions/*"],
      "pinDigests": false
    },
    {
      "matchManagers": ["npm"],
      "matchPackageNames": ["cesium"],
      "groupName": "cesium",
      "groupSlug": "cesium",
      "schedule": [
        "before 3:00 am on monday"
      ]
    },
    {
      "matchManagers": ["npm"],
      "excludePackageNames": ["cesium"],
      "groupName": "npm dependencies",
      "groupSlug": "npm",
      "schedule": [
        "before 3:00 am on monday"
      ]
    },
    {
      "matchManagers": ["gomod"],
      "groupName": "Go dependencies",
      "groupSlug": "gomod",
      "schedule": [
        "before 3:00 am on monday"
      ]
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "groupName": "Docker dependencies",
      "groupSlug": "docker",
      "schedule": [
        "before 3:00 am on monday"
      ]
    },
    {
      "matchManagers": ["terraform", "terraform-version"],
      "groupName": "Terraform dependencies",
      "groupSlug": "terraform",
      "semanticCommitType": "ci",
      "schedule": [
        "before 3:00 am on monday"
      ]
    },
    {
      "matchManagers": ["cargo"],
      "groupName": "Cargo dependencies",
      "groupSlug": "cargo",
      "schedule": [
        "before 3:00 am on monday"
      ]
    },
    {
      "matchManagers": ["pip_requirements", "pip_setup", "pipenv", "poetry", "pep621", "uv"],
      "groupName": "Python dependencies",
      "groupSlug": "python",
      "schedule": [
        "before 3:00 am on monday"
      ]
    }
  ]
}
